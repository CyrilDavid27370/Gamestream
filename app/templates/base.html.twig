<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}GameStream{% endblock %}</title>
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        {# ===== MESSAGES FLASH GLOBAUX ===== #}
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="container pt-3">
                    <div class="alert alert-{{ label == 'success' ? 'success' : (label == 'warning' ? 'warning' : 'danger') }} alert-dismissible fade show text-center" role="alert">
                        <i class="bi bi-check-circle"></i> {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                </div>
            {% endfor %}
        {% endfor %}

        {# ===== HEADER ===== #}
        <header class="text-center py-4 border-bottom border-primary">
            <h1 class="display-4 fw-bold text-primary">
                <i class="bi bi-controller"></i> GameStream
            </h1>
            <p class="text-secondary">Votre ludothèque, partout, à tout moment.</p>
        </header>

        {# ===== NAVBAR ===== #}
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-primary">
            <div class="container">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_game_index') }}">
                                <i class="bi bi-controller"></i> Ludothèque
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_search') }}">
                                <i class="bi bi-search"></i> Recherche
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_genre_index') }}">
                                <i class="bi bi-tags"></i> Catégories
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        {# ===== CONTENU DE LA PAGE ===== #}
        {% block body %}{% endblock %}

        {# ===== FOOTER ===== #}
        <footer class="text-center py-4 mt-5 border-top border-primary">
            <p class="text-secondary mb-0">© 2026 GameStream - Votre ludothèque personnelle</p>
        </footer>

        {# Bootstrap JS (pour dropdowns, modals, navbar, etc.) #}
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    </body>
</html>
