{% extends 'base.html.twig' %}

{% block title %}GameStream - Ma ludothèque{% endblock %}

{% block body %}
    {# ===== HEADER ===== #}
    <header class="text-center py-4 border-bottom border-primary">
        <h1 class="display-4 fw-bold text-primary">
            <i class="bi bi-controller"></i> GameStream
        </h1>
        <p class="text-secondary">Votre ludothèque, partout, à tout moment.</p>
    </header>

    {# ===== NAVBAR ===== #}
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-primary">
        <div class="container">
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item">
                        <a class="nav-link active" href="{{ path('app_game_index') }}">
                            <i class="bi bi-controller"></i> Ludothèque
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

{# ===== FILTRES PAR GENRE ===== #}
<div class="container py-3">
    <div class="d-flex flex-wrap justify-content-center gap-2">
        {# Bouton "Tous les jeux" #}
        <a href="{{ path('app_game_index') }}"
        class="btn {{ selectedGenre is null and playedFilter is null ? 'btn-primary' : 'btn-outline-primary' }} rounded-pill">
            Tous les jeux
        </a>

        {# Boutons Genres #}
        {% for genre in genres %}
            <a href="{{ path('app_game_index', {genre: genre.id}) }}"
            class="btn {{ selectedGenre == genre.id ? 'btn-primary' : 'btn-outline-primary' }} rounded-pill">
                {{ genre.name }}
            </a>
        {% endfor %}

        {# Bouton "Joué" #}
        <a href="{{ path('app_game_index', {played: 1}) }}"
        class="btn {{ playedFilter == '1' ? 'btn-primary' : 'btn-outline-primary' }} rounded-pill">
            <i class="bi bi-eye"></i>
        </a>

        {# Bouton "À jouer" #}
        <a href="{{ path('app_game_index', {played: 0}) }}"
        class="btn {{ playedFilter == '0' ? 'btn-primary' : 'btn-outline-primary' }} rounded-pill">
            <i class="bi bi-clock"></i>
        </a>
    </div>
</div>

    {# ===== MAIN ===== #}
    <main class="container py-4">
        <h2 class="mb-4 text-center">Ma ludothèque</h2>

        {% if games is empty %}
            <div class="alert alert-info text-center">
                <i class="bi bi-controller fs-1"></i>
                <p class="mt-2 mb-0">Votre ludothèque est vide. Commencez votre collection !</p>
            </div>
        {% else %}
            <div class="row g-4 justify-content-center">
                {% for game in games %}
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <a href="{{ path('app_game_show', {id: game.id}) }}" class="text-decoration-none text-reset">
                <div class="card h-100 shadow rounded-4 overflow-hidden">
                {% if game.backgroundImage %}
                    <img src="{{ game.backgroundImage }}" class="card-img-top" alt="{{ game.title }}" style="height: 200px; object-fit: cover;">
                {% else %}
                    <div class="card-img-top d-flex align-items-center justify-content-center bg-secondary" style="height: 200px;">
                        <i class="bi bi-controller" style="font-size: 4rem;"></i>
                    </div>
                {% endif %}
                <div class="card-body">
                    <h5 class="card-title text-truncate">{{ game.title }}</h5>
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-secondary">
                            <i class="bi bi-calendar"></i>
                            {{ game.released ? game.released|date('Y') : 'n/c' }}
                        </small>
                        <span class="badge {{ game.isPlayed ? 'bg-success' : 'bg-warning' }}">
                            {{ game.isPlayed ? '👁️ Joué' : '🕒 À jouer' }}
                        </span>
                    </div>
                </div>
            </div>
        </a>
    </div>
{% endfor %}
</div>
{% endif %}
</main>

    {# ===== FOOTER ===== #}
    <footer class="text-center py-4 mt-5 border-top border-primary">
        <p class="text-secondary mb-0">© 2026 GameStream - Votre ludothèque personnelle</p>
    </footer>
{% endblock %}
