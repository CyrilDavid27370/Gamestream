{% extends 'base.html.twig' %}

{% block title %}{{ game.title }} - GameStream{% endblock %}

{% block body %}
    {# ===== HEADER ===== #}
    <header class="text-center py-4 border-bottom border-primary">
        <h1 class="display-4 fw-bold text-primary">
            <i class="bi bi-controller"></i> GameStream
        </h1>
        <p class="text-secondary">Votre ludothèque, partout, à tout moment.</p>
    </header>

    {# ===== NAVBAR ===== #}
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-primary">
        <div class="container">
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_game_index') }}">
                            <i class="bi bi-controller"></i> Ludothèque
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_search') }}">
                            <i class="bi bi-search"></i> Recherche
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    {# ===== FICHE DU JEU ===== #}
    <main class="container py-4">
        <div class="card shadow rounded-4 overflow-hidden border border-primary" style="max-width: 900px; margin: 0 auto;">
            <div class="row g-0">
                {# Image à gauche #}
                <div class="col-md-4">
                    {% if game.backgroundImage %}
                        <img src="{{ game.backgroundImage }}" class="img-fluid h-100 w-100" alt="{{ game.title }}" style="object-fit: cover;">
                    {% else %}
                        <div class="d-flex align-items-center justify-content-center bg-secondary h-100" style="min-height: 300px;">
                            <i class="bi bi-controller" style="font-size: 5rem;"></i>
                        </div>
                    {% endif %}
                </div>

                {# Détails à droite #}
                <div class="col-md-8">
                    <div class="card-body">
                        {# En-tête avec titre + boutons #}
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h2 class="text-primary mb-0">{{ game.title }}</h2>
                            <div>
                                <a href="{{ path('app_game_update', {id: game.id}) }}" class="btn btn-outline-warning btn-sm">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post" action="{{ path('app_game_delete', {id: game.id}) }}"
                                onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer « {{ game.title }} » de votre ludothèque ?')"
                                style="display: inline;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ game.id) }}">
                                    <button type="submit" class="btn btn-outline-danger btn-sm">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </form>
                            </div>
                        </div>

                        {# Métadonnées #}
                        <p class="text-secondary mb-3">
                            <i class="bi bi-calendar"></i> {{ game.released ? game.released|date('Y') : 'n/c' }}
                            {% if game.playtime %}
                                | <i class="bi bi-clock"></i> {{ game.playtime }}h
                            {% endif %}
                            {% if game.genre %}
                                | <i class="bi bi-tag"></i> {{ game.genre.name }}
                            {% endif %}
                            |
                            <span class="badge {{ game.isPlayed ? 'bg-success' : 'bg-warning' }}">
                                {{ game.isPlayed ? '👁️ Joué' : '🕒 À jouer' }}
                            </span>
                        </p>

                        {# Plateformes #}
                        {% if game.platforms %}
                            <p class="text-secondary mb-3">
                                <i class="bi bi-pc-display"></i> <strong>Plateformes :</strong> {{ game.platforms }}
                            </p>
                        {% endif %}

                        {# Description personnelle #}
                        <div class="border border-primary rounded-3 p-3 mb-3" style="background-color: rgba(0,0,0,0.3);">
                            <h6 class="text-primary"><i class="bi bi-chat-quote"></i> Ma description</h6>
                            <p class="mb-0 fst-italic">
                                {{ game.description ?: 'Aucune description personnelle.' }}
                            </p>
                        </div>

                        {# Synopsis (overview) #}
                        <div>
                            <h6 class="text-primary"><i class="bi bi-file-text"></i> Synopsis</h6>
                            <p class="text-light">{{ game.overview ?: 'Aucun synopsis disponible.' }}</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Bouton retour #}
        <div class="text-center mt-4">
            <a href="{{ path('app_game_index') }}" class="btn btn-outline-primary rounded-pill">
                <i class="bi bi-arrow-left"></i> Retour à la ludothèque
            </a>
        </div>
    </main>

    {# ===== FOOTER ===== #}
    <footer class="text-center py-4 mt-5 border-top border-primary">
        <p class="text-secondary mb-0">© 2026 GameStream - Votre ludothèque personnelle</p>
    </footer>
{% endblock %}
