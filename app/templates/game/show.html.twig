{% extends 'base.html.twig' %}

{% block title %}{{ game.title }} - GameStream{% endblock %}

{% block body %}
    <main class="container py-4">
        <div class="card shadow rounded-4 overflow-hidden border border-primary" style="max-width: 900px; margin: 0 auto;">
            <div class="row g-0">
                {# Image à gauche #}
                <div class="col-md-4">
                    {% if game.backgroundImage %}
                        <div class="position-relative h-100" style="min-height: 400px; overflow: hidden;">
                            <div style="position: absolute; inset: 0; background-image: url('{{ game.backgroundImage }}'); background-size: cover; background-position: center; filter: blur(20px); transform: scale(1.1);"></div>
                            <img src="{{ game.backgroundImage }}"
                                alt="{{ game.title }}"
                                style="position: relative; width: 100%; height: 100%; object-fit: contain; z-index: 1;">
                        </div>
                    {% else %}
                        <div class="d-flex align-items-center justify-content-center bg-secondary h-100" style="min-height: 300px;">
                            <i class="bi bi-controller" style="font-size: 5rem;"></i>
                        </div>
                    {% endif %}
                </div>

                {# Détails à droite #}
                <div class="col-md-8">
                    <div class="card-body">
                        {# En-tête avec titre + boutons action #}
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h2 class="text-primary mb-0">{{ game.title }}</h2>
                            <div>
                                <a href="{{ path('app_game_update', {id: game.id}) }}" class="btn btn-outline-warning btn-sm" title="Modifier">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post" action="{{ path('app_game_delete', {id: game.id}) }}"
                                    onsubmit="return confirm('Supprimer « {{ game.title }} » de votre ludothèque ?')"
                                    style="display: inline;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ game.id) }}">
                                    <button type="submit" class="btn btn-outline-danger btn-sm" title="Supprimer">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </form>
                            </div>
                        </div>

                        {# Métadonnées #}
                        <p class="text-secondary mb-3">
                            <i class="bi bi-calendar"></i> {{ game.released ? game.released|date('Y') : 'n/c' }}
                            {% if game.playtime %}
                                | <i class="bi bi-clock"></i> {{ game.playtime }}h
                            {% endif %}
                            {% if game.genre %}
                                | <i class="bi bi-tag"></i> {{ game.genre.name }}
                            {% endif %}
                            |
                            <span class="badge {{ game.isPlayed ? 'bg-success' : 'bg-warning' }}">
                                {{ game.isPlayed ? '👁️ Joué' : '🕒 À jouer' }}
                            </span>
                        </p>

                        {# Note personnelle #}
                        {% if game.rating %}
                            <p class="mb-3">
                                <span class="badge bg-warning fs-6">
                                    <i class="bi bi-star-fill"></i> Ma note : {{ game.rating }}/10
                                </span>
                            </p>
                        {% endif %}

                        {# Plateformes #}
                        {% if game.platforms %}
                            <p class="text-secondary mb-3">
                                <i class="bi bi-pc-display"></i> <strong>Plateformes :</strong> {{ game.platforms }}
                            </p>
                        {% endif %}

                        {# Description personnelle #}
                        <div class="card bg-dark border-primary mb-3">
                            <div class="card-body">
                                <h6 class="text-primary"><i class="bi bi-chat-quote"></i> Ma description</h6>
                                <p class="text-light fst-italic mb-0">
                                    {{ game.description ?? 'Aucune description personnelle.' }}
                                </p>
                            </div>
                        </div>

                        {# Synopsis RAWG #}
                        {% if game.overview %}
                            <div>
                                <h6 class="text-primary"><i class="bi bi-file-text"></i> Synopsis</h6>
                                <p class="text-light">{{ game.overview }}</p>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        {# Bouton retour #}
        <div class="text-center mt-4">
            <a href="{{ path('app_game_index') }}" class="btn btn-outline-primary rounded-pill">
                <i class="bi bi-arrow-left"></i> Retour à la ludothèque
            </a>
        </div>
    </main>
{% endblock %}
