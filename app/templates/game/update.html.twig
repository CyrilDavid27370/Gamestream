{% extends 'base.html.twig' %}

{% block title %}Modifier {{ game.title }} - GameStream{% endblock %}

{% block body %}
    {# ===== HEADER ===== #}
    <header class="text-center py-4 border-bottom border-primary">
        <h1 class="display-4 fw-bold text-primary">
            <i class="bi bi-controller"></i> GameStream
        </h1>
        <p class="text-secondary">Votre ludothèque, partout, à tout moment.</p>
    </header>

    {# ===== NAVBAR ===== #}
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-primary">
        <div class="container">
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_game_index') }}">
                            <i class="bi bi-controller"></i> Ludothèque
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    {# ===== FORMULAIRE DE MODIFICATION ===== #}
    <main class="container py-4">
        <div class="card shadow rounded-4 overflow-hidden border border-primary" style="max-width: 700px; margin: 0 auto;">
            <div class="card-body p-4">
                <h2 class="text-primary text-center mb-4">
                    <i class="bi bi-pencil-square"></i> Modifier {{ game.title }}
                </h2>

                {{ form_start(form) }}
                    <div class="mb-3">
                        {{ form_label(form.genre) }}
                        {{ form_widget(form.genre) }}
                        {{ form_errors(form.genre) }}
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.description) }}
                        {{ form_widget(form.description) }}
                        {{ form_errors(form.description) }}
                    </div>

                    <div class="mb-4">
                        {{ form_label(form.isPlayed) }}
                        <div class="d-flex gap-3 mt-2">
                            {{ form_widget(form.isPlayed) }}
                        </div>
                        {{ form_errors(form.isPlayed) }}
                    </div>

                    <div class="text-center">
                        <button type="submit" class="btn btn-primary rounded-pill px-4">
                            <i class="bi bi-check-lg"></i> Enregistrer les modifications
                        </button>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>

        {# Bouton retour #}
        <div class="text-center mt-4">
            <a href="{{ path('app_game_show', {id: game.id}) }}" class="btn btn-outline-primary rounded-pill">
                <i class="bi bi-arrow-left"></i> Retour à la fiche
            </a>
        </div>
    </main>

    {# ===== FOOTER ===== #}
    <footer class="text-center py-4 mt-5 border-top border-primary">
        <p class="text-secondary mb-0">© 2026 GameStream - Votre ludothèque personnelle</p>
    </footer>
{% endblock %}
