{% extends 'base.html.twig' %}

{% block title %}Modifier {{ game.title }} - GameStream{% endblock %}

{% block body %}
    <main class="container py-4">
        <div class="card shadow rounded-4 overflow-hidden border border-primary" style="max-width: 600px; margin: 0 auto;">
            <div class="card-body p-4">
                <h2 class="text-primary text-center mb-4">
                    <i class="bi bi-pencil-square"></i> Modifier {{ game.title }}
                </h2>

                {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                    <div class="mb-3">
                        {{ form_label(form.genre) }}
                        {{ form_widget(form.genre) }}
                        <div class="text-danger mt-1">
                            {{ form_errors(form.genre) }}
                        </div>
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.description) }}
                        {{ form_widget(form.description) }}
                        <div class="text-danger mt-1">
                            {{ form_errors(form.description) }}
                        </div>
                    </div>

                    <div class="mb-4">
                        {{ form_label(form.isPlayed) }}
                        <div class="d-flex gap-3 mt-2">
                            {{ form_widget(form.isPlayed) }}
                        </div>
                    </div>

                    <div class="mb-4">
                        {{ form_label(form.rating) }}
                        {{ form_widget(form.rating) }}
                        <div class="text-danger mt-1">
                            {{ form_errors(form.rating) }}
                        </div>
                    </div>

                    <div class="text-center">
                        <button type="submit" class="btn btn-primary rounded-pill px-4">
                            <i class="bi bi-check-lg"></i> Enregistrer les modifications
                        </button>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>

        <div class="text-center mt-4">
            <a href="{{ path('app_game_show', {id: game.id}) }}" class="btn btn-outline-primary rounded-pill">
                <i class="bi bi-arrow-left"></i> Retour à la fiche
            </a>
        </div>
    </main>
{% endblock %}
