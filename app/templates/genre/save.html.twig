{% extends 'base.html.twig' %}

{% block title %}{{ isNew ? 'Nouvelle catégorie' : 'Modifier ' ~ genre.name }} - GameStream{% endblock %}

{% block body %}
    <main class="container py-4">
        <div class="card shadow rounded-4 overflow-hidden border border-primary" style="max-width: 500px; margin: 0 auto;">
            <div class="card-body p-4">
                <h2 class="text-primary text-center mb-4">
                    {% if isNew %}
                        <i class="bi bi-plus-circle"></i> Nouvelle catégorie
                    {% else %}
                        <i class="bi bi-pencil-square"></i> Modifier {{ genre.name }}
                    {% endif %}
                </h2>

                {{ form_start(form) }}
                    <div class="mb-3">
                        {{ form_label(form.name) }}
                        {{ form_widget(form.name) }}
                    </div>

                    <div class="text-center">
                        <button type="submit" class="btn btn-primary rounded-pill px-4">
                            <i class="bi bi-check-lg"></i>
                            {{ isNew ? 'Créer' : 'Enregistrer' }}
                        </button>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>

        <div class="text-center mt-4">
            <a href="{{ path('app_genre_index') }}" class="btn btn-outline-primary rounded-pill">
                <i class="bi bi-arrow-left"></i> Retour aux catégories
            </a>
        </div>
    </main>
{% endblock %}
